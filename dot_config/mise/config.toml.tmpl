[tools]
chezmoi = "latest"
node = "24"
python = "3.12"
lazygit = "latest"
gh = "latest"
yq = "latest"
atuin = "latest"
direnv = "latest"
delta = "latest"
jq = "latest"
neovim = "latest"
tree-sitter = "latest"
k9s = "latest"
kubectx = "latest"
kubens = "latest"
stern = "latest"
lazydocker = "latest"
tlrc = "latest"
yazi = "latest"
dust = "latest"
duf = "latest"
# Quét secret cho hook .githooks/pre-commit
gitleaks = "latest"
{{- if ne .chezmoi.os "windows" }}

# Thượng nguồn không phát hành bản Windows (mise báo "unsupported env: windows/amd64").
# Để ngoài guard thì `mise install` trên MỌI máy Windows đều fail, không riêng máy nào.
btop = "latest"
jless = "latest"
{{- end }}

[settings]
lockfile = true
idiomatic_version_file_enable_tools = []
