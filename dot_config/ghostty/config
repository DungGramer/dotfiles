font-family = Monaspace Neon NF
font-size = 11
theme = catppuccin-mocha.conf
shell-integration-features = no-cursor,sudo,no-title
background-opacity = 0.96

mouse-hide-while-typing = true
mouse-scroll-multiplier = 2
window-padding-balance = true 
window-save-state = always
window-padding-x = 8
window-padding-y = 8
cursor-style = block
mouse-hide-while-typing = true
shell-integration = zsh
clipboard-read = allow
clipboard-write = allow
copy-on-select = clipboard
gtk-titlebar = false
confirm-close-surface = false
window-save-state = always
window-inherit-working-directory = true
quit-after-last-window-closed = true

# Keybind
# Ctrl+V = paste (để Ghostty xử lý paste, không cho lọt xuống zsh thành quoted-insert
# -> đây là nguyên nhân gây leak ^[[200~ khi paste). Ctrl+Shift+V mặc định vẫn giữ.
keybind = ctrl+v=paste_from_clipboard
# Shift+Insert cũng paste qua Ghostty cho chắc (thay vì để app dưới tự xử lý)
keybind = shift+insert=paste_from_clipboard

keybind = ctrl+shift+n=new_window
keybind = ctrl+shift+t=new_tab

keybind = ctrl+page_down=next_tab
keybind = ctrl+page_up=previous_tab

keybind = ctrl+1=goto_tab:1
keybind = ctrl+2=goto_tab:2
keybind = ctrl+3=goto_tab:3
keybind = ctrl+4=goto_tab:4
keybind = ctrl+5=goto_tab:5
keybind = ctrl+6=goto_tab:6
keybind = ctrl+7=goto_tab:7
keybind = ctrl+8=goto_tab:8
keybind = ctrl+9=goto_tab:9

keybind = alt+enter=toggle_split_zoom
keybind = ctrl+shift+e=equalize_splits
keybind = ctrl+shift+r=reload_config
keybind = ctrl+shift+w=close_surface
keybind = f11=toggle_fullscreen
